<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PaceAI — Seu Treinador Virtual</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root {
  --bg: #0a0a0f;
  --bg2: #111118;
  --bg3: #1a1a24;
  --accent: #00ff87;
  --accent2: #00c4ff;
  --accent-dim: rgba(0,255,135,0.1);
  --accent-dim2: rgba(0,196,255,0.08);
  --text: #f0f0f0;
  --text2: #8888aa;
  --text3: #555570;
  --border: rgba(255,255,255,0.07);
  --border-accent: rgba(0,255,135,0.25);
  --radius: 16px;
  --radius-sm: 10px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden}

/* ── NOISE TEXTURE ── */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:.4}

/* ── GLOW ORBS ── */
.orb{position:fixed;border-radius:50%;filter:blur(80px);pointer-events:none;z-index:0}
.orb1{width:500px;height:500px;background:radial-gradient(circle,rgba(0,255,135,.12),transparent 70%);top:-100px;right:-100px}
.orb2{width:400px;height:400px;background:radial-gradient(circle,rgba(0,196,255,.08),transparent 70%);bottom:-80px;left:-80px}

/* ── SCREENS ── */
.screen{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:10;opacity:0;pointer-events:none;transition:opacity .4s ease}
.screen.active{opacity:1;pointer-events:all}

/* ── LOGIN ── */
.login-wrap{width:100%;max-width:420px;padding:24px}
.logo{text-align:center;margin-bottom:48px}
.logo-mark{font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:3px;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.logo-sub{font-size:13px;color:var(--text2);font-weight:300;letter-spacing:2px;text-transform:uppercase;margin-top:4px}
.login-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:32px;backdrop-filter:blur(20px)}
.login-title{font-size:22px;font-weight:600;margin-bottom:6px}
.login-desc{font-size:14px;color:var(--text2);margin-bottom:28px;font-weight:300}
.field{margin-bottom:16px}
.field label{display:block;font-size:12px;font-weight:500;color:var(--text2);margin-bottom:8px;text-transform:uppercase;letter-spacing:.08em}
.field input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:13px 16px;font-size:14px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s}
.field input:focus{border-color:var(--border-accent)}
.field input::placeholder{color:var(--text3)}
.btn-primary{width:100%;background:var(--accent);color:#000;border:none;border-radius:var(--radius-sm);padding:14px;font-size:15px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;letter-spacing:.02em}
.btn-primary:hover{background:#00e87a;transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,255,135,.25)}
.btn-primary:active{transform:translateY(0)}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;transform:none}
.divider{display:flex;align-items:center;gap:12px;margin:20px 0}
.divider span{font-size:12px;color:var(--text3)}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border)}
.btn-google{width:100%;background:transparent;border:1px solid var(--border);border-radius:var(--radius-sm);padding:13px;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;color:var(--text);transition:all .2s;display:flex;align-items:center;justify-content:center;gap:10px}
.btn-google:hover{border-color:rgba(255,255,255,.2);background:var(--bg3)}
.btn-google svg{width:18px;height:18px;flex-shrink:0}
.auth-switch{text-align:center;margin-top:20px;font-size:13px;color:var(--text2)}
.auth-switch a{color:var(--accent);cursor:pointer;text-decoration:none;font-weight:500}
.auth-switch a:hover{text-decoration:underline}
.error-msg{background:rgba(255,80,80,.1);border:1px solid rgba(255,80,80,.2);border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;color:#ff8080;margin-bottom:16px;display:none}
.error-msg.show{display:block}
.success-msg{background:rgba(0,255,135,.08);border:1px solid var(--border-accent);border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;color:var(--accent);margin-bottom:16px;display:none}
.success-msg.show{display:block}

/* ── ONBOARDING ── */
.ob-wrap{width:100%;max-width:560px;padding:24px}
.ob-header{margin-bottom:32px}
.ob-progress{display:flex;gap:6px;margin-bottom:20px}
.ob-prog-step{flex:1;height:3px;border-radius:2px;background:var(--border);transition:background .4s}
.ob-prog-step.done{background:var(--accent)}
.ob-prog-step.active{background:linear-gradient(90deg,var(--accent),var(--accent2))}
.ob-step-label{font-size:12px;color:var(--text2);text-transform:uppercase;letter-spacing:.1em}
.ob-title{font-family:'Bebas Neue',sans-serif;font-size:38px;letter-spacing:2px;margin-top:4px;line-height:1.1}
.ob-title span{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.ob-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:28px}
.ob-section-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.12em;margin-bottom:16px}
.ob-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.ob-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.ob-field{margin-bottom:14px}
.ob-field label{display:block;font-size:12px;font-weight:500;color:var(--text2);margin-bottom:7px;letter-spacing:.04em}
.ob-field input,.ob-field select{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 14px;font-size:14px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;-webkit-appearance:none}
.ob-field input:focus,.ob-field select:focus{border-color:var(--border-accent)}
.ob-field select option{background:var(--bg3)}
.ob-chips{display:flex;flex-wrap:wrap;gap:8px}
.chip{padding:8px 14px;border-radius:50px;border:1px solid var(--border);font-size:13px;color:var(--text2);cursor:pointer;transition:all .2s;background:transparent;font-family:'DM Sans',sans-serif}
.chip:hover{border-color:rgba(0,255,135,.3);color:var(--text)}
.chip.selected{background:var(--accent-dim);border-color:var(--border-accent);color:var(--accent)}
.ob-nav{display:flex;justify-content:space-between;align-items:center;margin-top:24px}
.btn-back{background:transparent;border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 20px;font-size:14px;color:var(--text2);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.btn-back:hover{border-color:rgba(255,255,255,.2);color:var(--text)}
.btn-next{background:var(--accent);color:#000;border:none;border-radius:var(--radius-sm);padding:12px 28px;font-size:14px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.btn-next:hover{background:#00e87a;transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,255,135,.25)}
.btn-next:disabled{opacity:.4;cursor:not-allowed;transform:none}
.step-panel{display:none}
.step-panel.active{display:block;animation:fadeUp .35s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── DASHBOARD ── */
.dash-wrap{width:100%;max-width:680px;padding:24px}
.dash-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:32px}
.dash-greeting{font-size:13px;color:var(--text2);margin-bottom:4px}
.dash-name{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:2px}
.dash-name span{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.btn-logout{background:transparent;border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 14px;font-size:12px;color:var(--text2);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.btn-logout:hover{border-color:rgba(255,80,80,.3);color:#ff8080}
.dash-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px}
.dash-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px}
.dash-card.accent-card{border-color:var(--border-accent);background:linear-gradient(135deg,rgba(0,255,135,.05),rgba(0,196,255,.03))}
.dc-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px}
.dc-value{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:1px}
.dc-value.green{color:var(--accent)}
.dc-sub{font-size:12px;color:var(--text2);margin-top:4px}
.dash-section-title{font-size:12px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:12px}
.treino-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;margin-bottom:10px;display:flex;align-items:center;gap:16px;transition:border-color .2s}
.treino-card:hover{border-color:rgba(255,255,255,.15)}
.treino-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.ti-leve{background:rgba(0,255,135,.1)}
.ti-interval{background:rgba(0,196,255,.1)}
.ti-longo{background:rgba(255,165,0,.1)}
.ti-descanso{background:rgba(255,255,255,.05)}
.treino-body{flex:1}
.treino-tipo{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
.treino-titulo{font-size:15px;font-weight:500}
.treino-meta{font-size:12px;color:var(--text2);margin-top:3px}
.treino-status{font-size:11px;font-weight:600;padding:4px 10px;border-radius:50px}
.ts-pendente{background:rgba(255,200,0,.1);color:#ffc800}
.ts-feito{background:rgba(0,255,135,.1);color:var(--accent)}
.ts-hoje{background:var(--accent);color:#000}
.chat-box{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-top:14px}
.chat-msgs{max-height:200px;overflow-y:auto;margin-bottom:16px;display:flex;flex-direction:column;gap:10px}
.msg{padding:10px 14px;border-radius:12px;font-size:13px;line-height:1.6;max-width:85%}
.msg.coach{background:var(--bg3);color:var(--text);align-self:flex-start}
.msg.atleta{background:var(--accent-dim);border:1px solid var(--border-accent);color:var(--text);align-self:flex-end}
.chat-input-row{display:flex;gap:10px}
.chat-input{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 14px;font-size:13px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s}
.chat-input:focus{border-color:var(--border-accent)}
.chat-input::placeholder{color:var(--text3)}
.btn-send{background:var(--accent);color:#000;border:none;border-radius:var(--radius-sm);padding:11px 18px;font-size:13px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.btn-send:hover{background:#00e87a}
.btn-send:disabled{opacity:.4;cursor:not-allowed}
.loading-dots::after{content:'...';animation:dots 1s infinite}
@keyframes dots{0%{content:'.'}33%{content:'..'}66%{content:'...'}}
.generate-btn{width:100%;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#000;border:none;border-radius:var(--radius-sm);padding:14px;font-size:15px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;margin-bottom:16px;letter-spacing:.02em}
.generate-btn:hover{transform:translateY(-1px);box-shadow:0 8px 28px rgba(0,255,135,.3)}
.generate-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
.tag{display:inline-block;font-size:11px;padding:3px 8px;border-radius:50px;background:rgba(0,196,255,.1);color:var(--accent2);margin-right:4px}
</style>
</head>
<body>
<div class="orb orb1"></div>
<div class="orb orb2"></div>

<!-- ══════════════ LOGIN ══════════════ -->
<div class="screen active" id="screen-login">
  <div class="login-wrap">
    <div class="logo">
      <div class="logo-mark">PaceAI</div>
      <div class="logo-sub">Seu treinador virtual inteligente</div>
    </div>
    <div class="login-card">
      <div class="login-title" id="auth-title">Entrar na sua conta</div>
      <div class="login-desc" id="auth-desc">Continue seu treinamento de onde parou.</div>
      <div class="error-msg" id="error-msg"></div>
      <div class="success-msg" id="success-msg"></div>
      <div class="field">
        <label>E-mail</label>
        <input type="email" id="input-email" placeholder="seu@email.com">
      </div>
      <div class="field" id="field-senha">
        <label>Senha</label>
        <input type="password" id="input-senha" placeholder="••••••••">
      </div>
      <div class="field" id="field-nome" style="display:none">
        <label>Seu nome</label>
        <input type="text" id="input-nome" placeholder="Como podemos te chamar?">
      </div>
      <button class="btn-primary" id="btn-auth" onclick="handleAuth()">Entrar</button>
      <div class="divider"><span>ou</span></div>
      <button class="btn-google" onclick="loginGoogle()">
        <svg viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Continuar com Google
      </button>
      <div class="auth-switch" id="auth-switch">
        Não tem conta? <a onclick="toggleMode()">Criar conta grátis</a>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════ ONBOARDING ══════════════ -->
<div class="screen" id="screen-onboarding">
  <div class="ob-wrap">
    <div class="ob-header">
      <div class="ob-progress">
        <div class="ob-prog-step active" id="prog-0"></div>
        <div class="ob-prog-step" id="prog-1"></div>
        <div class="ob-prog-step" id="prog-2"></div>
        <div class="ob-prog-step" id="prog-3"></div>
      </div>
      <div class="ob-step-label" id="ob-step-label">Passo 1 de 4</div>
      <div class="ob-title" id="ob-title">Vamos te <span>conhecer</span></div>
    </div>
    <div class="ob-card">

      <!-- Step 1: Dados pessoais -->
      <div class="step-panel active" id="step-0">
        <div class="ob-section-title">Dados pessoais</div>
        <div class="ob-grid">
          <div class="ob-field">
            <label>Nome completo</label>
            <input type="text" id="ob-nome" placeholder="Seu nome">
          </div>
          <div class="ob-field">
            <label>Data de nascimento</label>
            <input type="date" id="ob-nascimento">
          </div>
          <div class="ob-field">
            <label>Peso (kg)</label>
            <input type="number" id="ob-peso" placeholder="70">
          </div>
          <div class="ob-field">
            <label>Altura (cm)</label>
            <input type="number" id="ob-altura" placeholder="175">
          </div>
        </div>
        <div class="ob-field">
          <label>Sexo</label>
          <select id="ob-sexo">
            <option value="">Selecione</option>
            <option value="M">Masculino</option>
            <option value="F">Feminino</option>
            <option value="outro">Prefiro não informar</option>
          </select>
        </div>
      </div>

      <!-- Step 2: Experiência -->
      <div class="step-panel" id="step-1">
        <div class="ob-section-title">Sua experiência com corrida</div>
        <div class="ob-field">
          <label>Nível atual</label>
          <div class="ob-chips" id="chips-nivel">
            <button class="chip" data-val="iniciante" onclick="selectChip('nivel',this)">🌱 Iniciante</button>
            <button class="chip" data-val="intermediario" onclick="selectChip('nivel',this)">⚡ Intermediário</button>
            <button class="chip" data-val="avancado" onclick="selectChip('nivel',this)">🔥 Avançado</button>
          </div>
        </div>
        <div class="ob-grid" style="margin-top:16px">
          <div class="ob-field">
            <label>Pace médio (min/km)</label>
            <input type="number" id="ob-pace" placeholder="6.5" step="0.1">
          </div>
          <div class="ob-field">
            <label>Distância máxima (km)</label>
            <input type="number" id="ob-distmax" placeholder="10" step="0.1">
          </div>
          <div class="ob-field">
            <label>FC média (bpm)</label>
            <input type="number" id="ob-fc" placeholder="150">
          </div>
          <div class="ob-field">
            <label>Dias por semana</label>
            <select id="ob-dias">
              <option value="2">2 dias</option>
              <option value="3" selected>3 dias</option>
              <option value="4">4 dias</option>
              <option value="5">5 dias</option>
              <option value="6">6 dias</option>
            </select>
          </div>
        </div>
        <div class="ob-field">
          <label>Histórico de lesões (opcional)</label>
          <input type="text" id="ob-lesoes" placeholder="Ex: joelho direito em 2023, nenhuma...">
        </div>
      </div>

      <!-- Step 3: Objetivo -->
      <div class="step-panel" id="step-2">
        <div class="ob-section-title">Qual é seu objetivo principal?</div>
        <div class="ob-chips" id="chips-objetivo">
          <button class="chip" data-val="primeiros_5k" onclick="selectChip('objetivo',this)">🎯 Primeiros 5km</button>
          <button class="chip" data-val="primeiros_10k" onclick="selectChip('objetivo',this)">🎯 Primeiros 10km</button>
          <button class="chip" data-val="meia_maratona" onclick="selectChip('objetivo',this)">🏅 Meia maratona</button>
          <button class="chip" data-val="maratona" onclick="selectChip('objetivo',this)">🏆 Maratona</button>
          <button class="chip" data-val="melhorar_pace" onclick="selectChip('objetivo',this)">⚡ Melhorar pace</button>
          <button class="chip" data-val="emagrecimento" onclick="selectChip('objetivo',this)">🔥 Emagrecimento</button>
          <button class="chip" data-val="condicionamento" onclick="selectChip('objetivo',this)">💪 Condicionamento</button>
          <button class="chip" data-val="performance" onclick="selectChip('objetivo',this)">🥇 Performance</button>
          <button class="chip" data-val="pos_lesao" onclick="selectChip('objetivo',this)">🩹 Retorno pós-lesão</button>
          <button class="chip" data-val="recreativo" onclick="selectChip('objetivo',this)">😊 Recreativo</button>
        </div>
        <div class="ob-grid" style="margin-top:20px">
          <div class="ob-field">
            <label>Tempo disponível por treino</label>
            <select id="ob-tempo">
              <option value="30">30 minutos</option>
              <option value="45">45 minutos</option>
              <option value="60" selected>1 hora</option>
              <option value="90">1h30</option>
              <option value="120">2 horas+</option>
            </select>
          </div>
          <div class="ob-field">
            <label>Acesso a academia?</label>
            <select id="ob-academia">
              <option value="false">Não</option>
              <option value="true">Sim</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Step 4: Prova alvo -->
      <div class="step-panel" id="step-3">
        <div class="ob-section-title">Tem uma prova no horizonte?</div>
        <div class="ob-field">
          <label>Nome da prova (opcional)</label>
          <input type="text" id="ob-prova" placeholder="Ex: Maratona de SP, Corrida das Rosas...">
        </div>
        <div class="ob-field">
          <label>Data da prova (opcional)</label>
          <input type="date" id="ob-dataprova">
        </div>
        <div class="ob-field" style="margin-top:8px">
          <label>Histórico esportivo</label>
          <input type="text" id="ob-historico" placeholder="Ex: joguei futebol por 5 anos, pratico crossfit...">
        </div>
        <div style="margin-top:20px;padding:16px;background:var(--accent-dim);border:1px solid var(--border-accent);border-radius:var(--radius-sm)">
          <div style="font-size:12px;color:var(--accent);font-weight:600;margin-bottom:4px">🤖 Pronto para conhecer seu treinador!</div>
          <div style="font-size:13px;color:var(--text2);line-height:1.6">Com esses dados, a IA vai criar seu primeiro plano de treino personalizado. Você pode ajustar tudo depois.</div>
        </div>
      </div>

      <div class="ob-nav">
        <button class="btn-back" id="btn-ob-back" onclick="obBack()" style="visibility:hidden">← Voltar</button>
        <button class="btn-next" id="btn-ob-next" onclick="obNext()">Continuar →</button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════ DASHBOARD ══════════════ -->
<div class="screen" id="screen-dashboard">
  <div class="dash-wrap">
    <div class="dash-top">
      <div>
        <div class="dash-greeting">Bom treino,</div>
        <div class="dash-name"><span id="dash-nome">Atleta</span> 👟</div>
      </div>
      <button class="btn-logout" onclick="logout()">Sair</button>
    </div>

    <div class="dash-cards">
      <div class="dash-card accent-card">
        <div class="dc-label">Objetivo atual</div>
        <div class="dc-value green" id="dash-objetivo" style="font-size:20px;font-family:'DM Sans';font-weight:600">—</div>
        <div class="dc-sub" id="dash-nivel">—</div>
      </div>
      <div class="dash-card">
        <div class="dc-label">Treinos esta semana</div>
        <div class="dc-value" id="dash-treinos-semana">0/3</div>
        <div class="dc-sub">sessões concluídas</div>
      </div>
    </div>

    <div class="dash-section-title">Seu plano de treino</div>
    <button class="generate-btn" id="btn-gerar" onclick="gerarPlano()">
      ✨ Gerar meu plano com IA
    </button>
    <div id="treinos-lista"></div>

    <div class="dash-section-title" style="margin-top:20px">Coach Virtual</div>
    <div class="chat-box">
      <div class="chat-msgs" id="chat-msgs">
        <div class="msg coach">Olá! Sou seu coach virtual 🤖 Pode me perguntar sobre seus treinos, dores, fadiga ou qualquer dúvida sobre corrida.</div>
      </div>
      <div class="chat-input-row">
        <input class="chat-input" id="chat-input" placeholder="Ex: Hoje estou cansado, posso treinar?" onkeydown="if(event.key==='Enter')sendChat()">
        <button class="btn-send" id="btn-send" onclick="sendChat()">Enviar</button>
      </div>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════
// CONFIGURAÇÃO SUPABASE
// ══════════════════════════════════════════
const SUPABASE_URL = 'https://kvfpulkirlssuhxefxsk.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imt2ZnB1bGtpcmxzc3VoeGVmeHNrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg1MzY0NzQsImV4cCI6MjA5NDExMjQ3NH0.3z4wiVo6DYYsBB7N7ncvSiLm6YsdFPnI2AvNbTkAgjM';
const { createClient } = supabase;
const sb = createClient(SUPABASE_URL, SUPABASE_KEY);

// ══════════════════════════════════════════
// ESTADO GLOBAL
// ══════════════════════════════════════════
let currentUser = null;
let atletaPerfil = null;
let obStep = 0;
let obData = { nivel: null, objetivo: null };
let isLogin = true;

// ══════════════════════════════════════════
// INICIALIZAÇÃO
// ══════════════════════════════════════════
async function init() {
  const { data: { session } } = await sb.auth.getSession();
  if (session) {
    currentUser = session.user;
    await checkOnboarding();
  } else {
    showScreen('login');
  }
  sb.auth.onAuthStateChange(async (event, session) => {
    if (session) {
      currentUser = session.user;
      await checkOnboarding();
    } else {
      currentUser = null;
      showScreen('login');
    }
  });
}

async function checkOnboarding() {
  const { data } = await sb.from('atletas').select('*').eq('id', currentUser.id).single();
  atletaPerfil = data;
  if (!data || !data.onboarding_completo) {
    if (data?.nome) document.getElementById('ob-nome').value = data.nome;
    showScreen('onboarding');
  } else {
    await loadDashboard();
    showScreen('dashboard');
  }
}

function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
}

// ══════════════════════════════════════════
// AUTH
// ══════════════════════════════════════════
let authMode = 'login';

function toggleMode() {
  authMode = authMode === 'login' ? 'signup' : 'login';
  const isLogin = authMode === 'login';
  document.getElementById('auth-title').textContent = isLogin ? 'Entrar na sua conta' : 'Criar conta grátis';
  document.getElementById('auth-desc').textContent = isLogin ? 'Continue seu treinamento de onde parou.' : 'Comece sua jornada de corrida hoje.';
  document.getElementById('btn-auth').textContent = isLogin ? 'Entrar' : 'Criar conta';
  document.getElementById('field-nome').style.display = isLogin ? 'none' : 'block';
  document.getElementById('auth-switch').innerHTML = isLogin
    ? 'Não tem conta? <a onclick="toggleMode()">Criar conta grátis</a>'
    : 'Já tem conta? <a onclick="toggleMode()">Entrar</a>';
  clearMsgs();
}

async function handleAuth() {
  const email = document.getElementById('input-email').value.trim();
  const senha = document.getElementById('input-senha').value;
  const btn = document.getElementById('btn-auth');
  clearMsgs();
  if (!email || !senha) { showError('Preencha e-mail e senha.'); return; }
  btn.disabled = true;
  btn.textContent = authMode === 'login' ? 'Entrando...' : 'Criando conta...';
  try {
    if (authMode === 'login') {
      const { error } = await sb.auth.signInWithPassword({ email, password: senha });
      if (error) throw error;
    } else {
      const nome = document.getElementById('input-nome').value.trim();
      const { error } = await sb.auth.signUp({ email, password: senha, options: { data: { full_name: nome } } });
      if (error) throw error;
      showSuccess('Conta criada! Verifique seu e-mail se necessário.');
    }
  } catch (e) {
    showError(traduzirErro(e.message));
    btn.disabled = false;
    btn.textContent = authMode === 'login' ? 'Entrar' : 'Criar conta';
  }
}

async function loginGoogle() {
  await sb.auth.signInWithOAuth({ provider: 'google', options: { redirectTo: window.location.href } });
}

async function logout() {
  await sb.auth.signOut();
}

function traduzirErro(msg) {
  if (msg.includes('Invalid login')) return 'E-mail ou senha incorretos.';
  if (msg.includes('already registered')) return 'Este e-mail já está cadastrado.';
  if (msg.includes('Password should')) return 'A senha deve ter pelo menos 6 caracteres.';
  return msg;
}

function showError(msg) { const el = document.getElementById('error-msg'); el.textContent = msg; el.classList.add('show'); }
function showSuccess(msg) { const el = document.getElementById('success-msg'); el.textContent = msg; el.classList.add('show'); }
function clearMsgs() { document.getElementById('error-msg').classList.remove('show'); document.getElementById('success-msg').classList.remove('show'); }

// ══════════════════════════════════════════
// ONBOARDING
// ══════════════════════════════════════════
const obTitles = [
  { label: 'Passo 1 de 4', title: 'Vamos te <span>conhecer</span>' },
  { label: 'Passo 2 de 4', title: 'Sua <span>experiência</span>' },
  { label: 'Passo 3 de 4', title: 'Seu <span>objetivo</span>' },
  { label: 'Passo 4 de 4', title: 'Quase <span>lá!</span>' },
];

function updateObUI() {
  document.querySelectorAll('.step-panel').forEach((p, i) => p.classList.toggle('active', i === obStep));
  document.querySelectorAll('.ob-prog-step').forEach((p, i) => {
    p.classList.toggle('done', i < obStep);
    p.classList.toggle('active', i === obStep);
  });
  document.getElementById('ob-step-label').textContent = obTitles[obStep].label;
  document.getElementById('ob-title').innerHTML = obTitles[obStep].title;
  document.getElementById('btn-ob-back').style.visibility = obStep === 0 ? 'hidden' : 'visible';
  document.getElementById('btn-ob-next').textContent = obStep === 3 ? 'Criar meu plano 🚀' : 'Continuar →';
}

function selectChip(group, el) {
  document.querySelectorAll(`#chips-${group} .chip`).forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  obData[group] = el.dataset.val;
}

function obBack() { if (obStep > 0) { obStep--; updateObUI(); } }

async function obNext() {
  if (obStep < 3) { obStep++; updateObUI(); return; }
  // Salvar onboarding
  const btn = document.getElementById('btn-ob-next');
  btn.disabled = true; btn.textContent = 'Salvando...';
  const payload = {
    nome: document.getElementById('ob-nome').value || null,
    data_nascimento: document.getElementById('ob-nascimento').value || null,
    peso_kg: parseFloat(document.getElementById('ob-peso').value) || null,
    altura_cm: parseInt(document.getElementById('ob-altura').value) || null,
    sexo: document.getElementById('ob-sexo').value || null,
    nivel: obData.nivel || 'iniciante',
    pace_medio_min_km: parseFloat(document.getElementById('ob-pace').value) || null,
    distancia_maxima_km: parseFloat(document.getElementById('ob-distmax').value) || null,
    fc_media: parseInt(document.getElementById('ob-fc').value) || null,
    dias_disponiveis: parseInt(document.getElementById('ob-dias').value) || 3,
    historico_lesoes: document.getElementById('ob-lesoes').value || null,
    objetivo: obData.objetivo || 'condicionamento',
    tempo_disponivel_min: parseInt(document.getElementById('ob-tempo').value) || 60,
    acesso_academia: document.getElementById('ob-academia').value === 'true',
    prova_alvo: document.getElementById('ob-prova').value || null,
    data_prova: document.getElementById('ob-dataprova').value || null,
    historico_esportivo: document.getElementById('ob-historico').value || null,
    onboarding_completo: true,
  };
  const { error } = await sb.from('atletas').update(payload).eq('id', currentUser.id);
  if (error) { btn.disabled = false; btn.textContent = 'Criar meu plano 🚀'; alert('Erro ao salvar: ' + error.message); return; }
  atletaPerfil = { ...atletaPerfil, ...payload };
  await loadDashboard();
  showScreen('dashboard');
}

// ══════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════
const objetivoLabels = {
  primeiros_5k:'Primeiros 5km', primeiros_10k:'Primeiros 10km',
  meia_maratona:'Meia Maratona', maratona:'Maratona',
  melhorar_pace:'Melhorar Pace', emagrecimento:'Emagrecimento',
  condicionamento:'Condicionamento', performance:'Performance',
  pos_lesao:'Retorno pós-lesão', recreativo:'Recreativo', hibrido:'Híbrido'
};
const nivelLabels = { iniciante:'🌱 Iniciante', intermediario:'⚡ Intermediário', avancado:'🔥 Avançado' };

async function loadDashboard() {
  if (!atletaPerfil) return;
  const nome = atletaPerfil.nome || currentUser.email.split('@')[0];
  document.getElementById('dash-nome').textContent = nome;
  document.getElementById('dash-objetivo').textContent = objetivoLabels[atletaPerfil.objetivo] || '—';
  document.getElementById('dash-nivel').textContent = nivelLabels[atletaPerfil.nivel] || '—';
  // Carregar sessões da semana
  const hoje = new Date();
  const seg = new Date(hoje); seg.setDate(hoje.getDate() - hoje.getDay() + 1);
  const dom = new Date(seg); dom.setDate(seg.getDate() + 6);
  const { data: sessoes } = await sb.from('sessoes_treino')
    .select('*').eq('atleta_id', currentUser.id)
    .gte('data_prevista', seg.toISOString().split('T')[0])
    .lte('data_prevista', dom.toISOString().split('T')[0])
    .order('data_prevista');
  if (sessoes && sessoes.length > 0) {
    document.getElementById('btn-gerar').style.display = 'none';
    renderSessoes(sessoes);
    const feitos = sessoes.filter(s => s.status === 'feito').length;
    document.getElementById('dash-treinos-semana').textContent = `${feitos}/${sessoes.length}`;
  }
}

function renderSessoes(sessoes) {
  const icons = { rodagem_leve:'🏃', longao:'🛣️', intervalado:'⚡', fartlek:'🌊', progressivo:'📈', regenerativo:'🌿', tempo_run:'⏱️', subida:'⛰️', tiros_curtos:'💨', tiros_longos:'🎯', fortalecimento:'💪', mobilidade:'🧘', recuperacao_ativa:'♻️', descanso:'😴' };
  const iconClass = { rodagem_leve:'ti-leve', longao:'ti-longo', intervalado:'ti-interval', fartlek:'ti-interval', progressivo:'ti-interval', regenerativo:'ti-leve', tempo_run:'ti-interval', subida:'ti-longo', tiros_curtos:'ti-interval', tiros_longos:'ti-interval', fortalecimento:'ti-leve', mobilidade:'ti-leve', recuperacao_ativa:'ti-leve', descanso:'ti-descanso' };
  const hoje = new Date().toISOString().split('T')[0];
  const lista = document.getElementById('treinos-lista');
  lista.innerHTML = sessoes.map(s => {
    const isHoje = s.data_prevista === hoje;
    const statusLabel = isHoje && s.status === 'pendente' ? '<span class="treino-status ts-hoje">HOJE</span>' : s.status === 'feito' ? '<span class="treino-status ts-feito">✓ Feito</span>' : '<span class="treino-status ts-pendente">Pendente</span>';
    const data = new Date(s.data_prevista + 'T12:00:00').toLocaleDateString('pt-BR', { weekday:'short', day:'numeric', month:'short' });
    return `<div class="treino-card">
      <div class="treino-icon ${iconClass[s.tipo]||'ti-leve'}">${icons[s.tipo]||'🏃'}</div>
      <div class="treino-body">
        <div class="treino-tipo">${data}</div>
        <div class="treino-titulo">${s.titulo}</div>
        <div class="treino-meta">${s.distancia_meta_km ? s.distancia_meta_km+'km' : ''} ${s.duracao_meta_min ? '· '+s.duracao_meta_min+'min' : ''} ${s.pace_alvo_min_km ? '· Pace ~'+s.pace_alvo_min_km+'/km' : ''}</div>
      </div>
      ${statusLabel}
    </div>`;
  }).join('');
}

// ══════════════════════════════════════════
// GERAR PLANO COM IA
// ══════════════════════════════════════════
async function gerarPlano() {
  const btn = document.getElementById('btn-gerar');
  btn.disabled = true; btn.textContent = '🤖 A IA está criando seu plano...';
  try {
    // Chamar a Edge Function do Supabase (criaremos a seguir)
    const { data, error } = await sb.functions.invoke('gerar-plano', {
      body: { atleta_id: currentUser.id }
    });
    if (error) throw error;
    await loadDashboard();
    btn.style.display = 'none';
  } catch (e) {
    btn.disabled = false; btn.textContent = '✨ Gerar meu plano com IA';
    // Modo demo: mostrar treinos de exemplo
    const demo = [
      { tipo:'rodagem_leve', titulo:'Rodagem Leve de Adaptação', data_prevista: dataRelativa(1), distancia_meta_km:5, duracao_meta_min:40, pace_alvo_min_km:7.0, status:'pendente' },
      { tipo:'descanso', titulo:'Descanso Ativo', data_prevista: dataRelativa(2), distancia_meta_km:null, duracao_meta_min:null, pace_alvo_min_km:null, status:'pendente' },
      { tipo:'intervalado', titulo:'Intervalado 4x800m', data_prevista: dataRelativa(3), distancia_meta_km:6, duracao_meta_min:50, pace_alvo_min_km:5.5, status:'pendente' },
      { tipo:'descanso', titulo:'Recuperação', data_prevista: dataRelativa(4), distancia_meta_km:null, duracao_meta_min:null, pace_alvo_min_km:null, status:'pendente' },
      { tipo:'longao', titulo:'Longão do Fim de Semana', data_prevista: dataRelativa(6), distancia_meta_km:10, duracao_meta_min:70, pace_alvo_min_km:7.5, status:'pendente' },
    ];
    renderSessoes(demo);
    addChatMsg('coach', 'Plano de demonstração carregado! Para ativar a IA completa, precisamos configurar a Edge Function no Supabase. Me pergunte qualquer coisa sobre seus treinos! 🏃');
  }
}

function dataRelativa(dias) {
  const d = new Date(); d.setDate(d.getDate() + dias);
  return d.toISOString().split('T')[0];
}

// ══════════════════════════════════════════
// CHAT COM COACH IA
// ══════════════════════════════════════════
let chatHistory = [];

async function sendChat() {
  const input = document.getElementById('chat-input');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';
  addChatMsg('atleta', msg);
  chatHistory.push({ role: 'user', content: msg });
  const btn = document.getElementById('btn-send');
  btn.disabled = true; btn.textContent = '...';
  try {
    const { data, error } = await sb.functions.invoke('coach-chat', {
      body: { mensagem: msg, atleta_id: currentUser.id, historico: chatHistory.slice(-6) }
    });
    if (error) throw error;
    const resposta = data.resposta;
    addChatMsg('coach', resposta);
    chatHistory.push({ role: 'assistant', content: resposta });
    // Salvar no banco
    await sb.from('conversas_coach').insert([
      { atleta_id: currentUser.id, remetente: 'atleta', mensagem: msg },
      { atleta_id: currentUser.id, remetente: 'coach', mensagem: resposta }
    ]);
  } catch (e) {
    // Resposta local de fallback
    const respostas = [
      'Boa pergunta! Para respostas personalizadas com IA, precisamos ativar a Edge Function do Supabase. Em breve você terá um coach inteligente! 💪',
      'Entendo sua dúvida! A IA completa estará disponível após configurarmos a integração com a Claude API. Continue treinando! 🏃',
      'Ótima pergunta! Em breve o coach IA vai responder com base nos seus dados reais do Garmin e histórico de treinos. 🤖'
    ];
    addChatMsg('coach', respostas[Math.floor(Math.random() * respostas.length)]);
  }
  btn.disabled = false; btn.textContent = 'Enviar';
}

function addChatMsg(tipo, texto) {
  const msgs = document.getElementById('chat-msgs');
  const div = document.createElement('div');
  div.className = `msg ${tipo}`;
  div.textContent = texto;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

// ══════════════════════════════════════════
// START
// ══════════════════════════════════════════
init();
</script>
</body>
</html>
